rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /rooms/{roomCode} {
      allow read: if true;
      allow write: if false;

      match /players/{playerId} {
        allow read: if true;
        allow write: if false;
      }

      match /rounds/{roundNumber} {
        allow read: if true;
        allow write: if false;

        match /guesses/{playerId} {
          allow read: if true;
          allow write: if false;
        }
      }
    }
  }
}
